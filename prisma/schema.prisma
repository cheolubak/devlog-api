generator client {
  provider        = "prisma-client"
  output          = "../src/database/generated/prisma"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "postgresql"
}

enum FeedType {
  RSS
  ATOM
  SCRAPING
  YOUTUBE
}

enum FetchStatus {
  PENDING
  SUCCESS
  FAILED
  PARTIAL
}

enum RegionType {
  KOREA
  FOREIGN

  @@map("region_type")
}

enum SocialType {
  KAKAO
  NAVER
  GOOGLE
  GITHUB

  @@map("social_type")
}

model Users {
  id         String     @db.Uuid @id @default(uuid())
  nickname   String     @db.VarChar(50)
  email      String?    @db.VarChar(150)
  profile    String?    @db.VarChar(200)
  socialType SocialType @map("social_type")
  socialId   String     @db.VarChar(100) @map("social_id")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @default(now()) @map("updated_at")

  postBookmarks PostBookmarks[]

  @@unique([socialId, socialType])
  @@map("users")
}

model BlogSource {
  id                String      @db.Uuid @id @default(uuid())
  name              String      @db.VarChar(100)
  url               String      @unique @db.VarChar(500)
  type              FeedType    @default(RSS)
  scrapingConfig    Json?
  metadata          Json?
  icon              String?
  isActive          Boolean     @default(true)
  lastFetchedAt     DateTime?
  lastFetchStatus   FetchStatus @default(PENDING)
  lastFetchError    String?     @db.Text
  totalPostsFetched Int         @default(0)
  region            RegionType
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt @default(now())
  posts             Posts[]
  blogUrl           String
  corpUrl           String?     @db.VarChar(100) @map("corp_url")

  @@index([isActive])
  @@index([lastFetchedAt])
}

model BlogSourceFetchQueue {
  sourceId  String   @db.Uuid @id @map("source_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("blog_source_fetch_queue")
}

model Posts {
  id                  String              @db.Uuid @id @default(uuid())
  title               String              @db.VarChar(200)
  titleEn             String?             @db.VarChar(300) @map("title_en")
  description         String?             @db.Text
  descriptionEn       String?             @db.Text @map("description_en")
  isDisplay           Boolean             @default(false)
  tags                String?             @db.VarChar(100)
  sourceId            String?             @db.Uuid
  sourceUrl           String?             @unique @db.VarChar(500)
  originalPublishedAt DateTime?
  originalAuthor      String?             @db.VarChar(100)
  imageUrl            String?             @db.VarChar(150)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt @default(now())
  viewCount           Int                 @default(0) @map("view_count")
  postTags            PostTags[]
  searchKeywords      PostSearchKeywords?
  source              BlogSource?         @relation(fields: [sourceId], references: [id])
  deletionLog         PostDeletionLog?

  postBookmarks PostBookmarks[]

  @@index([sourceId])
  @@index([isDisplay])
  @@index([originalPublishedAt])
  @@index([isDisplay, originalPublishedAt])
}

model PostSearchKeywords {
  postId    String   @unique @db.Uuid
  keywords  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())
  post      Posts    @relation(fields: [postId], references: [id])

  @@index([postId])
}

model PostDeletionLog {
  postId    String   @unique @db.Uuid
  deletedAt DateTime @default(now())
  post      Posts    @relation(fields: [postId], references: [id])

  @@index([postId])
  @@index([postId, deletedAt])
}

model Tags {
  id       Int        @id @default(autoincrement())
  name     String     @unique @db.VarChar(50)
  count    Int
  postTags PostTags[]

  @@index([name])
}

model PostTags {
  postId    String   @db.Uuid
  tagId     Int
  createdAt DateTime @default(now())
  post      Posts    @relation(fields: [postId], references: [id])
  tag       Tags     @relation(fields: [tagId], references: [id])

  @@id([postId, tagId])
  @@index([tagId])
}

model PostBookmarks {
  userId    String   @db.Uuid @map("user_id")
  postId    String   @db.Uuid @map("post_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      Users    @relation(fields: [userId], references: [id])
  post      Posts    @relation(fields: [postId], references: [id])

  @@id([userId, postId])
  @@map("post_bookmarks")
}

model ApiDailyUsage {
  id       Int      @id @default(autoincrement())
  provider String   @db.VarChar(50)
  date     DateTime @db.Date
  count    Int      @default(0)

  @@unique([provider, date])
  @@index([date])
  @@map("api_daily_usage")
}

model PostViewHistory {
  id        Int      @id @default(autoincrement())
  postId    String   @db.Uuid @map("post_id")
  userId    String?  @db.Uuid @map("user_id")
  sessionId String?  @db.Uuid @map("session_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([postId])
  @@index([userId])
  @@index([sessionId])
  @@map("post_view_history")
}
